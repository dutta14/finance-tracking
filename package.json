    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.0.0",
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "msw": "^2.13.4",
    "typescript": "^5.0.0",
    "vite": "^4.3.0",
